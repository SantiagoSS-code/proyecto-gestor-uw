rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Each user can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Players ───────────────────────────────────────────────────────────
    match /players/{userId} {
      // Each player can read and write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Centers (new schema) ─────────────────────────────────────────────
    match /centers/{centerId} {
      // Public read – the player landing & club-detail pages need this
      allow read: if true;
      // Authenticated center owner can write their own center doc
      allow write: if request.auth != null && request.auth.uid == centerId;

      match /courts/{courtId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /bookings/{bookingId} {
        // Public read so the availability grid can show occupied slots
        allow read: if true;
        // Authenticated players can create pending bookings
        allow create: if request.auth != null;
        // Allow updates (confirm / cancel / expire) from authenticated users
        allow update: if request.auth != null;
        // Only server-side (Admin SDK) may delete
        allow delete: if false;
      }

      match /classes/{classId} {
        allow read: if true;
        allow write: if false;
      }

      match /reviews/{reviewId} {
        // Anyone can read reviews (public ratings)
        allow read: if true;
        // Authenticated players can create reviews; only the author can update/delete
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }

      // ── Courses – public read for published+public courses (player-facing pages)
      match /courses/{courseId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /courses/{courseId}/{nested=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      // ── All other subcollections (courses, trainers, classSessions,
      //    trainerSettlements, customers, finances, reports, etc.)
      //    Only the center owner can read/write.
      match /{subcollection}/{docId} {
        allow read:  if request.auth != null && request.auth.uid == centerId;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      // Nested subcollections (e.g. courses/{courseId}/sessions/{sessionId})
      match /{subcollection}/{docId}/{nested=**} {
        allow read:  if request.auth != null && request.auth.uid == centerId;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }
    }

    // ── Legacy centers (padel_centers) ────────────────────────────────────
    match /padel_centers/{centerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == centerId;

      match /courts/{courtId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /availability/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == centerId;
      }

      match /bookings/{bookingId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }

    // ── Catch-all: deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Promotions module ─────────────────────────────────────────────────

    // discounts – club admin manages their own; players can read active ones
    match /discounts/{discountId} {
      // Club owner full access
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      // Authenticated players can read active discounts (for checkout validation)
      allow read: if request.auth != null
        && resource.data.status == "active";
      // Club owner can create
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // campaigns – club admin only
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // segments – club admin only
    match /segments/{segmentId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // discount_assignments – club admin or assigned player can read
    match /discount_assignments/{docId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.clubId
            || request.auth.uid == resource.data.userId);
      allow write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // discount_redemptions – club admin reads; authenticated player creates their own
    match /discount_redemptions/{docId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.clubId
            || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      // No updates or deletes – immutable audit trail
      allow update, delete: if false;
    }

    // ai_recommendations – club admin only
    match /ai_recommendations/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // ── Memberships module ────────────────────────────────────────────────

    // membership_plans – club admin CRUD; authenticated players can read active plans
    match /membership_plans/{planId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow read: if request.auth != null
        && resource.data.status == "active";
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // membership_benefits – club admin only
    match /membership_benefits/{benefitId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // membership_rules – club admin only
    match /membership_rules/{ruleId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // membership_subscriptions – club admin CRUD; subscribed player can read own
    match /membership_subscriptions/{subscriptionId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.clubId;
    }

    // membership_usage – club admin reads; authenticated player can increment own usage
    match /membership_usage/{usageId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // membership_events – club admin reads; no direct client writes (server-side only)
    match /membership_events/{eventId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.clubId;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
