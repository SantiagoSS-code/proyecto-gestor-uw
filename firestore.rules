rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Centers (new schema) ─────────────────────────────────────────────
    match /centers/{centerId} {
      // Public read – the player landing & club-detail pages need this
      allow read: if true;
      // Only authenticated center admins may write (handled by Admin SDK on server)
      allow write: if false;

      match /courts/{courtId} {
        allow read: if true;
        allow write: if false;
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if false;
      }

      match /bookings/{bookingId} {
        // Public read so the availability grid can show occupied slots
        allow read: if true;
        // Authenticated players can create pending bookings
        allow create: if request.auth != null;
        // Allow updates (confirm / cancel / expire) from authenticated users
        allow update: if request.auth != null;
        // Only server-side (Admin SDK) may delete
        allow delete: if false;
      }

      match /classes/{classId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Legacy centers (padel_centers) ────────────────────────────────────
    match /padel_centers/{centerId} {
      allow read: if true;
      allow write: if false;

      match /courts/{courtId} {
        allow read: if true;
        allow write: if false;
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if false;
      }

      match /availability/{docId} {
        allow read: if true;
        allow write: if false;
      }

      match /bookings/{bookingId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }

    // ── Catch-all: deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
